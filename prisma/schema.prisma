generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DocumentBundle {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  formType    FormType
  status      BundleStatus @default(NEW)

  // Identifikácia žiadateľa
  ico         String
  companyName String
  applicantName String       // meno + priezvisko

  // Dáta formulára (celý JSON stav formulára)
  formData    Json

  // Vygenerovaný XML (vypĺňa správca)
  xmlContent  String?

  // Podpis splnomocnenia (base64 PNG)
  signatureBase64 String?

  // Poznámka správcu
  adminNote   String?

  // Prílohy
  attachments Attachment[]
}

model Attachment {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())

  // Prepojenie na žiadosť
  bundleId   String
  bundle     DocumentBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  // Metadáta súboru
  fileName   String         // pôvodný názov súboru
  attachmentType String     // typ prílohy: "zivnostenskyList", "zmluva", "ine"
  mimeType   String         // "application/pdf"
  sizeBytes  Int

  // Binárne dáta (PDF uložené priamo v DB)
  data       Bytes
}

enum FormType {
  PD_A1
  UPLATNITELNA_LEGISLATIVA
}

enum BundleStatus {
  NEW          // práve podaná
  REVIEWED     // správca skontroloval
  SUBMITTED    // odoslané na SP
  COMPLETED    // vybavené
}
